        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ contents: [{ parts: [{ text: $json.valoracion_prompt }] }], generationConfig: { temperature: 0.3, topP: 0.9, maxOutputTokens: 20000 } }) }}",
        "options": {
