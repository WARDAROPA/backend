    {
      "parameters": {
        "jsCode": "// 1. Obtenemos el array de noticias que está dentro de la propiedad 'data' del primer item\nconst noticias = $input.first().json.data;\n\n// Si no hay noticias, salimos\nif (!noticias || noticias.length === 0) {\n    return [];\n}\n\n// 2. Inicializamos las variables usando la primera noticia del array\nlet ganadora = noticias[0];\nlet maxPuntuacion = noticias[0].puntuacion || 0;\n\n// 3. Iteramos sobre el resto de las noticias dentro de 'data'\nfor (let i = 1; i < noticias.length; i++) {\n    const puntuacion = noticias[i].puntuacion || 0;\n    \n    if (puntuacion > maxPuntuacion) {\n        maxPuntuacion = puntuacion;\n        ganadora = noticias[i];\n    }\n}\n\n// 4. Devolvemos la noticia ganadora con la estructura que n8n espera\nreturn [{ json: ganadora }];"
      },
