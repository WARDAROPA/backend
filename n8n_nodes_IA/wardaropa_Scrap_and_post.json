        -496
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const geminiResponse = $input.first();\nconst preparacionData = $('Preparar Valoracion2').first().json;\nconst noticiasOriginales = preparacionData.noticias_originales || [];\nconst results = [];\n\nlet puntuaciones = [];\n\ntry {\n  const text = geminiResponse.json.candidates[0].content.parts[0].text;\n  const cleanText = text.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  let parsedData = JSON.parse(cleanText);\n  \n  // SOLUCIÓN 1: Si la IA devuelve un solo objeto, lo convertimos en array\n  if (!Array.isArray(parsedData)) {\n    puntuaciones = [parsedData];\n  } else {\n    puntuaciones = parsedData;\n  }\n} catch (e) {\n  // Si falla el parseo general, creamos un array falso para no romper el flujo\n  puntuaciones = [];\n}\n\n// Mapear puntuaciones a noticias originales\nfor (let i = 0; i < noticiasOriginales.length; i++) {\n  const noticia = noticiasOriginales[i];\n  const puntuacionData = puntuaciones.find(p => p.id === i);\n  \n  let puntuacionFinal = 5; // Nota por defecto\n  \n// SOLUCIÓN 2 MEJORADA (Detecta si es número u objeto)\n  if (puntuacionData && puntuacionData.puntuacion !== undefined) {\n      const valorPuntuacion = puntuacionData.puntuacion;\n\n      if (typeof valorPuntuacion === 'object' && valorPuntuacion !== null) {\n          // CASO A: Es un objeto { \"Japón\": 1, \"EEUU\": 4... }\n          const notas = Object.values(valorPuntuacion);\n          if (notas.length > 0) {\n              const notasNumericas = notas.map(n => parseInt(n) || 0);\n              puntuacionFinal = Math.max(...notasNumericas);\n          }\n      } else {\n          // CASO B: Es un número directo (como en tu última captura)\n          puntuacionFinal = parseInt(valorPuntuacion) || 0;\n      }\n  }\n  \n  results.push({\n    json: {\n      enlace: noticia.enlace || '',\n      titulo: noticia.titulo || '',\n      descripcion: noticia.descripcion || '',\n      fuente: noticia.fuente || '',\n      fecha_publicacion: noticia.fecha_publicacion || '',\n      puntuacion: puntuacionFinal,\n      puntuacion_str: String(puntuacionFinal),\n      estado: noticia.estado || 'nueva'\n    }\n  });\n}\n\nreturn results;"
      },
