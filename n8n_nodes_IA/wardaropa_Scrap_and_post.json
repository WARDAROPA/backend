        "jsCode": "const item = $input.first();\n// Asegúrate de que el nombre del nodo anterior coincide con el tuyo\nconst prev = $('Preparar Prompt SEO2').first().json; \nlet aiResponse = {};\n\ntry {\n  const text = item.json.candidates[0].content.parts[0].text;\n  const cleanText = text.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  aiResponse = JSON.parse(cleanText);\n} catch (e) {\n  // Valores de rescate en caso de que la IA no devuelva un JSON válido\n  aiResponse = {\n    titulo_seo: prev.titulo || 'Sin título',\n    contenido_seo: prev.descripcion || 'Sin contenido',\n    extracto: (prev.descripcion || '').substring(0, 160),\n    palabras_clave: ['moda', 'tendencias', 'lifestyle'],\n    prompt_imagen: 'High-end fashion editorial photography, stylish and modern clothing, elegant lighting, vogue magazine style, photorealistic'\n  };\n}\n\nreturn [{\n  json: {\n    titulo_original: prev.titulo || '',\n    enlace_original: prev.enlace || '',\n    fuente: prev.fuente || '',\n    fecha_publicacion: prev.fecha_publicacion || '',\n    fecha_proceso: new Date().toISOString(),\n    puntuacion: String(prev.puntuacion || '10'),\n    titulo_seo: aiResponse.titulo_seo || '',\n    contenido_seo: aiResponse.contenido_seo || '',\n    extracto: aiResponse.extracto || '',\n    palabras_clave: Array.isArray(aiResponse.palabras_clave) ? aiResponse.palabras_clave.join(', ') : '',\n    prompt_imagen: aiResponse.prompt_imagen || 'High fashion runway or editorial street style photography, elegant, highly detailed'\n  }\n}];"
